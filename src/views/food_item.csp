<%inc
#include "../dto/food.h"
%>

<%c++
    auto fd=@@.get<Food>("food");
%>

<%c++ if(fd.ID){%>
    <tr>
      <th scope="row">{%fd.ID%}</th>
      <td>{%fd.name%}</td>
      <td>{%fd.quantity%}</td>
      <td>{%fd.quantity_type%}</td>
      <td>{%fd.protein%}</td>
      <td>{%fd.calories%}</td>
    </tr>
<%c++ }%>