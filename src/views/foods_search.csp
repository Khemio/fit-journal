<%inc
#include "../models/food.h"
%>

<%c++
    auto foods=@@.get<std::vector<Food>>("foods");
%>

<%c++ if(foods.size()>0){%>
    <%c++ for(const auto& fd : foods){%>
      <tr>
        <th scope="row">{%fd.ID%}</th>
        <td>{%fd.name%}</td>
        <td>{%fd.quantity%}</td>
        <td>{%fd.quantity_type%}</td>
        <td>{%fd.protein%}</td>
        <td>{%fd.calories%}</td>
      </tr>
      <%c++}%>
<%c++ }%>